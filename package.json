{
  "name": "@iyulab/components",
  "description": "web-components library based on lit-element made by iyulab",
  "version": "0.4.0",
  "keywords": [
    "iyulab",
    "components",
    "web-components",
    "lit",
    "lit-element"
  ],
  "license": "MIT",
  "author": "iyulab",
  "repository": {
    "type": "git",
    "url": "https://github.com/iyulab/node-components.git"
  },
  "files": [
    "dist",
    "skills",
    "LICENSE",
    "README.md",
    "CHANGELOG.md",
    "package.json"
  ],
  "type": "module",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./src/index.d.ts",
      "import": "./src/index.js"
    },
    "./dist/*": {
      "types": "./src/*.d.ts",
      "import": "./src/*"
    },
    "./react-components": "./dist/react-components/index.js",
    "./react-components/*": "./dist/react-components/*"
  },
  "scripts": {
    "test": "vite --force",
    "build": "eslint && vite build"
  },
  "dependencies": {
    "@floating-ui/dom": "^1.7.6",
    "@lit/react": "^1.0.8",
    "focus-trap": "^8.0.1",
    "lit": "^3.3.2"
  },
  "peerDependencies": {
    "react": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^25.5.0",
    "eslint": "^9.39.4",
    "eslint-plugin-lit": "^2.2.1",
    "globals": "^17.4.0",
    "react": "^19.2.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.2",
    "vite": "^8.0.3",
    "vite-plugin-dts": "^4.5.4",
    "vite-plugin-static-copy": "^4.0.0"
  }
}
